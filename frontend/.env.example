# Frontend Environment Variables
# Copy to .env.local for local development
# Set these in Render dashboard for production

# Backend API URL (required for WebSocket and API calls)
NEXT_PUBLIC_API_URL=https://servio-backend-zexb.onrender.com
NEXT_PUBLIC_BACKEND_URL=https://servio-backend-zexb.onrender.com

# For local development, use:
# NEXT_PUBLIC_API_URL=http://localhost:3002
# NEXT_PUBLIC_BACKEND_URL=http://localhost:3002
