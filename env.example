 ...## Servio Backend environment variables
## Copy to `backend/.env` (or export in your shell) and fill in values.

# Server
PORT=3002
FRONTEND_URL=http://localhost:3000

# Auth
# IMPORTANT: change this in production.
JWT_SECRET=dev_insecure_jwt_secret_change_me

# OpenAI (required for STT/LLM/TTS features)
OPENAI_API_KEY=

# MiniMax AI Configuration (primary AI provider - ~96% cheaper than OpenAI)
# Get your API key at: https://platform.minimax.io/
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1
MINIMAX_CHAT_MODEL=m2.1
MINIMAX_TTS_VOICE=male-shaun-2

# Text-to-Speech (optional overrides)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Deepgram Speech-to-Text (alternative to Whisper for kitchen assistant)
DEEPGRAM_API_KEY=

# ElevenLabs Text-to-Speech (high-quality voice for kitchen assistant)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Kitchen Assistant Timer Configuration
KITCHEN_TIMER_INTERVAL=1000

# Vapi Voice AI Configuration (for phone ordering)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_RESTAURANT_ID=

# Stripe Payments (required for online card checkout)
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd

# Optional DB config (defaults to local SQLite in ./data)
# DATABASE_URL=
# DATABASE_SSL=false

# Browser Automation Configuration
# Set to 'false' for testing (see browser), 'true' for production (headless)
HEADLESS=true

# Twilio SMS Configuration (for marketing features)
# Get these from your Twilio Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email Configuration (Outlook / Microsoft 365 e.g. GoDaddy 365)
# SMTP host is usually smtp.office365.com and TLS on port 587.
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Base URL for public links and QR codes
BASE_URL=http://localhost:3000

# Web Push Notifications (VAPID keys for PWA push notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BBrpGfTsn1t1iBT9Y-TGF5bEi60HWyWNsBSA58Pb3pn_aO2WhgMRkG3Xm2-Y8P7eyEjU08snZvtJ-p3iXCNF-nE
VAPID_PRIVATE_KEY=jF5JgG4g6B2k-CqjvEJ6J_rFWF2N3YMuk4YuPQhwMKw
VAPID_EMAIL=mailto:admin@servio.com
